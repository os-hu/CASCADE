{
  "_comment": [
    "Full CASCADE config that wires in ReflectionAnalysis as the analysis step.",
    "CodeGenerator and TestGenerator stay at the TOP LEVEL — PipelineFactory",
    "builds the Generation object from them and passes it as 'generator' to",
    "ReflectionAnalysis, which forwards it to JavaTwoStepAnalysis internally.",
    "Run with:",
    "  CASCADE run -i <project-root> -o <output> -c configs/reflectionConfig.json",
    "  --module-path ./  (so PipelineFactory can find the reflection package)"
  ],

  "Extraction": { "name": "JavaExtraction", "kwargs": {} },

  "CodeGenerator": {
    "name": "JavaCodeGenerator",
    "kwargs": {
      "model":       "gpt-4.1-mini",
      "temperature": 0.2,
      "api_key": "dummy"
    }
  },

  "TestGenerator": {
    "name": "MultiStepJavaTestGenerator",
    "kwargs": {
      "model":       "gpt-4.1-mini",
      "api_key": "dummy",
      "temperature": 0.4
    }
  },

  "Executor": { "name": "MavenJavaExecutor", "kwargs": {} },

  "FilterFunctions": [
    { "name": "NoTestsFilterFunction",  "kwargs": {} },
    { "name": "ContainsFilterFunction", "kwargs": { "key": "doc", "content": "@inheritDoc", "invert": true } },
    { "name": "CheckLengthFilterFunction", "kwargs": { "key": "code", "op": ">", "val": 0 } },
    { "name": "CheckLengthFilterFunction", "kwargs": { "key": "doc",  "op": ">", "val": 12 } },
    { "name": "ContainsFilterFunction", "kwargs": { "key": "signature.modifier", "content": "public" } }
  ],

  "Analysis": {
    "name": "ReflectionAnalysis",
    "kwargs": {
      
      "inner_analysis": {
        "name": "JavaTwoStepAnalysis",
        "kwargs": {
          
        }
      },

      "reflector": {
        "name": "ChainedReflector",
        "kwargs": {
          "escalation_threshold": 0.65,
          "api_key": "your-openai-api-key-here",
          "diff_kwargs": {
            "min_diff_lines":     1,
            "confidence_floor":   0.30,
            "confidence_ceiling": 0.95
          },
          "llm_kwargs": {
            "model":                        "gpt-4.1-mini",
            "temperature":                  0.0,
            "require_synthesized_doc":      false,
            "confidence_boost_on_doc_delta": 0.1
          }
        }
      },

      "only_flagged": true,

      "input_key_code":       "code",
      "input_key_synth_code": "new_code",
      "input_key_doc":        "doc",
      "input_key_synth_doc":  "synthesized_doc"
    }
  }
}